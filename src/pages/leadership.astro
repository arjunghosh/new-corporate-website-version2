---
import { readFile } from 'node:fs/promises';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { site } from '@/data/site';

const source = await readFile(new URL('../../../../leadership.html', import.meta.url), 'utf8');
const normalized = source.replaceAll('https://flexilytics.ai', site.url);

const title = normalized.match(/<title>([\s\S]*?)<\/title>/i)?.[1]?.trim() ?? 'Leadership — Flexilytics';
const description =
  normalized.match(/<meta\s+name="description"\s+content="([^"]*)"/i)?.[1]?.trim() ??
  site.description;
const inlineStyles = normalized.match(/<style>([\s\S]*?)<\/style>/i)?.[1]?.trim() ?? '';
const schemas = Array.from(
  normalized.matchAll(/<script type="application\/ld\+json">\s*([\s\S]*?)\s*<\/script>/gi),
  (match) => JSON.parse(match[1]),
);
const mainHtml = normalized.match(/<main>([\s\S]*?)<\/main>/i)?.[1]?.trim() ?? '';

const normalizeMainHtml = (html: string) =>
  html
    .replaceAll('href="assets/', 'href="/assets/')
    .replaceAll("href='assets/", "href='/assets/")
    .replaceAll('src="assets/', 'src="/assets/')
    .replaceAll("src='assets/", "src='/assets/")
    .replaceAll('href="index.html"', 'href="/"')
    .replaceAll("href='index.html'", "href='/'")
    .replaceAll('href="book-audit.html"', 'href="/book-audit"')
    .replaceAll("href='book-audit.html'", "href='/book-audit'")
    .replaceAll('href="about.html"', 'href="/about"')
    .replaceAll("href='about.html'", "href='/about'")
    .replaceAll('href="leadership.html"', 'href="/leadership"')
    .replaceAll("href='leadership.html'", "href='/leadership'")
    .replaceAll('href="approach.html"', 'href="/approach"')
    .replaceAll("href='approach.html'", "href='/approach'")
    .replaceAll('href="solutions.html"', 'href="/solutions"')
    .replaceAll("href='solutions.html'", "href='/solutions'")
    .replaceAll('href="platforms.html"', 'href="/platforms"')
    .replaceAll("href='platforms.html'", "href='/platforms'")
    .replaceAll('href="trust-security.html"', 'href="/trust-security"')
    .replaceAll("href='trust-security.html'", "href='/trust-security'")
    .replaceAll('href="insights.html"', 'href="/insights"')
    .replaceAll("href='insights.html'", "href='/insights'")
    .replaceAll('href="solutions-data-governance.html"', 'href="/solutions-data-governance"')
    .replaceAll("href='solutions-data-governance.html'", "href='/solutions-data-governance'")
    .replaceAll('href="solutions-modern-data-platform.html"', 'href="/solutions-modern-data-platform"')
    .replaceAll("href='solutions-modern-data-platform.html'", "href='/solutions-modern-data-platform'")
    .replaceAll('href="solutions-ai-ml-engineering.html"', 'href="/solutions-ai-ml-engineering"')
    .replaceAll("href='solutions-ai-ml-engineering.html'", "href='/solutions-ai-ml-engineering'")
    .replaceAll('href="solutions-analytics-bi.html"', 'href="/solutions-analytics-bi"')
    .replaceAll("href='solutions-analytics-bi.html'", "href='/solutions-analytics-bi'")
    .replaceAll('href="solutions-flexianalyst.html"', 'href="/solutions-flexianalyst"')
    .replaceAll("href='solutions-flexianalyst.html'", "href='/solutions-flexianalyst'")
    .replaceAll('href="bfsi.html"', 'href="/industries/bfsi"')
    .replaceAll("href='bfsi.html'", "href='/industries/bfsi'");
---

<BaseLayout
  title={title}
  description={description}
  canonical={`${site.url}/leadership`}
  ogImage={`${site.url}/og/leadership.png`}
  inlineStyles={inlineStyles}
  schemas={schemas}
  activePath="/about"
>
  <Fragment set:html={normalizeMainHtml(mainHtml)} />
</BaseLayout>
